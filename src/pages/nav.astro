---

<BaseLayout title="网址导航">
  <main class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-serif mb-4 text-center">🔗 网址导航</h1>
    <p class="text-center text-secondary mb-12">收集优质网站，提升工作效率</p>
    
    <div class="space-y-12">
      {categories.map(category => (
        <section>
          <h2 class="text-2xl font-serif mb-6 flex items-center gap-2">
            <span>{category.icon}</span>
            <span>{category.name}</span>
          </h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
            {category.links.map(link => (
              <a 
                href={link.url}
                target="_blank"
                class="card group p-4 hover:border-accent/50 transition-all"
              >
                <h3 class="text-lg font-medium group-hover:text-accent transition-colors mb-2">
                  {link.name}
                </h3>
                <p class="text-sm text-secondary">{link.desc}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <div class="card mt-12 text-center">
      <h2 class="text-2xl font-serif mb-4">📮 提交网站</h2>
      <p class="text-secondary">发现好网站？欢迎在 GitHub 提交 Issue 推荐</p>
    </div>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import GithubStats from '../components/GithubStats.astro';

const skills = [
  { name: 'JavaScript/TypeScript', level: 80, color: 'bg-[#F0DB4F]' },
  { name: 'Python', level: 70, color: 'bg-[#3776AB]' },
  { name: 'Astro', level: 75, color: 'bg-[#FF5D01]' },
  { name: 'Linux运维', level: 85, color: 'bg-[#FCC624]' }
];

const timeline = [
  { year: "2024", title: "接触编程", desc: "开始学习编程，探索技术世界" },
  { year: "2025", title: "搭建博客", desc: "建立个人博客，记录学习历程" },
  { year: "2026", title: "持续成长", desc: "不断学习新技术，拓展技能边界" }
];
---

<BaseLayout title="关于">
  <main class="max-w-4xl mx-auto px-4 py-12 space-y-16">
    <!-- GitHub统计 -->
      <GithubStats username="a997282418" />

    <!-- 技能图谱 -->
    <div class="card group">
      <h2 class="text-3xl font-serif mb-8">🛠 技能图谱</h2>
      <div class="space-y-6">
        {skills.map(skill => (
          <div class="animate-fade-in">
            <div class="flex justify-between mb-2 text-sm font-medium">
              <span>{skill.name}</span>
              <span class="text-accent">{skill.level}%</span>
            </div>
            <div class="h-3 bg-accent/10 rounded-full overflow-hidden">
              <div 
                class={`h-full ${skill.color} rounded-full transition-all duration-1000 ease-out`}
                style={`width: ${skill.level}%`}
              />
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 时间轴 -->
    <div class="card">
      <h2 class="text-3xl font-serif mb-8">⏳ 成长轨迹</h2>
      <div class="relative pl-8">
        {/* 时间轴线 */}
        <div class="absolute left-0 top-4 bottom-4 w-px bg-gradient-to-b from-accent/20 via-accent/50 to-accent/20" />
        
        {timeline.map((item, index) => (
          <div class="relative mb-12 group">
            {/* 时间节点装饰 */}
            <div class="absolute left-[-34px] top-1 flex h-8 w-8 items-center justify-center rounded-full bg-accent shadow-lg transition-transform group-hover:scale-110">
              <svg class="h-4 w-4 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>

            {/* 内容卡片 */}
            <div class="pl-8">
              <div class="flex items-baseline gap-4 mb-2">
                <span class="text-2xl font-bold text-accent">{item.year}</span>
                <span class="text-lg font-medium opacity-80">{item.title}</span>
              </div>
              <p class="text-secondary pl-2 border-l-2 border-accent/30 leading-relaxed">
                {item.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 关于我 -->
    <div class="card bg-surface/50">
      <h2 class="text-3xl font-serif mb-8">😎 关于我</h2>
      <div class="prose dark:prose-invert">
        <p>一个热爱技术的学习者，正在探索编程的无限可能。</p>
        <p>喜欢折腾各种新技术，享受解决问题的过程。在这里记录学习笔记和技术心得。</p>
        <blockquote>
          "保持好奇，持续学习"
        </blockquote>
      </div>
    </div>

    <!-- 关于本站 -->
    <div class="card bg-surface/50">
      <h2 class="text-3xl font-serif mb-8">🌌 关于本站</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="prose dark:prose-invert">
          <h3>技术栈</h3>
          <ul>
            <li>Astro - 现代静态站点生成器</li>
            <li>Tailwind CSS - 实用优先的CSS框架</li>
            <li>Vercel - 全球边缘部署平台</li>
          </ul>
        </div>
        <div class="prose dark:prose-invert">
          <h3>设计理念</h3>
          <ul>
            <li>简洁优雅的视觉体验</li>
            <li>响应式设计，多端适配</li>
            <li>专注内容，减少干扰</li>
          </ul>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  /* 时间轴优化样式 */
  .timeline-node {
    box-shadow: 0 4px 6px -1px rgba(var(--color-accent), 0.1);
  }
  
  @media (max-width: 768px) {
    .timeline-content {
      padding-left: 2rem;
    }
  }
</style>
